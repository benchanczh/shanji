        {"name": "蚝油", "qty": 20, "unit": "ml"},
        {"name": "生抽", "qty": 10, "unit": "ml"},
        {"name": "淀粉", "qty": 10, "unit": "g"},
        {"name": "姜", "qty": 10, "unit": "g"},
        {"name": "葱", "qty": 2, "unit": "根"},
        {"name": "食用油", "qty": 20, "unit": "ml"},
        {"name": "白糖", "qty": null, "unit": "适量"}
