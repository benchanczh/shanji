    {
      "name": "清蒸鲈鱼", "name_en": "Steamed sea bass", "cuisine": "粤菜", "course": "main",
      "minutes": 25, "difficulty": "easy", "protein_type": "fish",
      "nutrition_tags": ["high_protein", "low_oil"], "baby_adaptable": true,
      "ingredients": [
        {"name": "鲈鱼", "qty": 1, "unit": "条", "note": "约600g"},
        {"name": "姜", "qty": 20, "unit": "g", "note": "切丝"},
        {"name": "葱", "qty": 2, "unit": "根", "note": "切丝"},
        {"name": "蒸鱼豉油", "qty": 30, "unit": "ml"},
        {"name": "食用油", "qty": 15, "unit": "ml"},
        {"name": "料酒", "qty": null, "unit": "适量"}
      ],
      "steps": [
        {"cn": "鲈鱼洗净两面划刀，抹少许料酒，鱼身铺姜丝。", "en": "Clean the fish and score both sides. Rub with a little cooking wine and lay ginger strips on top."},
        {"cn": "水开后入锅大火蒸8分钟，关火再焖2分钟，倒掉盘中汁水。", "en": "Steam over high heat for 8 minutes after the water boils, rest 2 minutes off heat, then pour away the liquid in the plate."},
        {"cn": "给宝宝从鱼背取一小块无刺鱼肉。换新葱姜丝铺面，淋蒸鱼豉油，浇热油激香。", "en": "Take a small boneless piece from the back for the baby. Top with fresh scallion and ginger, pour steamed fish soy sauce, then drizzle with hot oil.", "baby_split_point": true}
      ]
    },
    {
      "name": "白切鸡", "name_en": "White cut chicken", "cuisine": "粤菜", "course": "main",
      "minutes": 45, "difficulty": "medium", "protein_type": "chicken",
      "nutrition_tags": ["high_protein"], "baby_adaptable": false,
      "ingredients": [
        {"name": "三黄鸡", "qty": 1, "unit": "只"},
        {"name": "姜", "qty": 50, "unit": "g"},
        {"name": "葱", "qty": 3, "unit": "根"},
        {"name": "盐", "qty": null, "unit": "适量"},
        {"name": "食用油", "qty": 20, "unit": "ml"}
      ],
      "steps": [
        {"cn": "整鸡冷水下锅，加姜片葱结，水开后转小火浸煮约25分钟。", "en": "Put the whole chicken in cold water with ginger and scallion knots. Bring to a boil, then poach on low heat for about 25 minutes."},
        {"cn": "捞出立即过冰水，让鸡皮收紧爽滑。", "en": "Transfer immediately into ice water to firm up the skin."},
        {"cn": "姜葱切末加盐，浇热油做蘸料，斩件装盘。", "en": "Mince ginger and scallion with salt, pour hot oil over to make the dip. Chop the chicken and serve."}
      ]
    },
    {
      "name": "豉汁蒸排骨", "name_en": "Steamed pork ribs with black bean sauce", "cuisine": "粤菜", "course": "main",
      "minutes": 30, "difficulty": "easy", "protein_type": "pork",
      "nutrition_tags": ["high_protein"], "baby_adaptable": false,
      "ingredients": [
        {"name": "排骨", "qty": 400, "unit": "g", "note": "斩小段"},
        {"name": "豆豉", "qty": 15, "unit": "g"},
        {"name": "蒜", "qty": 15, "unit": "g"},
        {"name": "生抽", "qty": 15, "unit": "ml"},
        {"name": "白糖", "qty": 5, "unit": "g"},
        {"name": "淀粉", "qty": 10, "unit": "g"},
        {"name": "食用油", "qty": 10, "unit": "ml"}
      ],
      "steps": [
        {"cn": "排骨冲洗血水沥干，加豆豉碎、蒜末、生抽、糖、淀粉和油抓匀，腌15分钟。", "en": "Rinse and drain the ribs. Mix well with chopped black beans, minced garlic, soy sauce, sugar, starch and oil. Marinate 15 minutes."},
        {"cn": "平铺浅盘，水开后大火蒸12分钟至熟透。", "en": "Spread on a shallow plate. Steam over high heat for 12 minutes until cooked through."}
      ]
    },
    {
