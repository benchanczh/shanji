      "steps": [
        {"cn": "牛肉片加生抽、淀粉和少许油抓匀，腌10分钟。", "en": "Mix beef slices with soy sauce, starch and a little oil. Marinate 10 minutes."},
        {"cn": "热锅冷油下姜片爆香，大火快炒牛肉至变色盛出。", "en": "Heat oil with ginger slices, stir-fry beef on high heat until just browned, remove."},
        {"cn": "锅内加蚝油、少许糖和水煮开，倒回牛肉和葱段翻匀即可。", "en": "Boil oyster sauce with a little sugar and water in the wok, return the beef with scallion and toss to coat."}
      ]
    },
    {
      "name": "滑蛋虾仁", "name_en": "Scrambled eggs with shrimp", "cuisine": "粤菜", "course": "main",
      "minutes": 15, "difficulty": "easy", "protein_type": "shrimp",
      "nutrition_tags": ["high_protein", "quick"], "baby_adaptable": true,
      "ingredients": [
        {"name": "虾仁", "qty": 200, "unit": "g"},
        {"name": "鸡蛋", "qty": 4, "unit": "个"},
        {"name": "盐", "qty": null, "unit": "适量"},
        {"name": "淀粉", "qty": 5, "unit": "g"},
        {"name": "食用油", "qty": 20, "unit": "ml"},
        {"name": "葱", "qty": 1, "unit": "根"}
      ],
      "steps": [
        {"cn": "虾仁用淀粉抓洗后冲净，焯水20秒捞出。", "en": "Rub shrimp with starch, rinse, then blanch for 20 seconds and drain."},
        {"cn": "给宝宝留几只虾仁和一勺蛋液单独炒熟（不加盐）。", "en": "Set aside a few shrimp and a spoonful of egg for the baby, cooked separately without salt.", "baby_split_point": true},
        {"cn": "蛋液加盐打散，拌入虾仁，热锅中小火倒入，轻推至半凝固撒葱花出锅。", "en": "Beat eggs with salt, fold in shrimp. Pour into a hot pan over medium-low heat, gently push until just set, finish with scallion."}
