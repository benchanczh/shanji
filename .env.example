# AI provider (Anthropic-compatible endpoint; Kimi/Moonshot or Anthropic)
# International Moonshot: https://api.moonshot.ai/anthropic
# China Moonshot:         https://api.moonshot.cn/anthropic
# Anthropic (default):    leave SHANJI_AI_BASE_URL unset
SHANJI_AI_BASE_URL=https://api.moonshot.ai/anthropic
SHANJI_AI_API_KEY=sk-your-key-here
SHANJI_AI_MODEL_FAST=kimi-k2.5
SHANJI_AI_MODEL_GEN=kimi-k2.6

# Server (defaults shown; override if ports clash)
# SHANJI_PORT=8090
# SHANJI_DATABASE_URL=postgres://shanji:shanji@localhost:5433/shanji?sslmode=disable
# SHANJI_JWT_SECRET=dev-secret-change-me
